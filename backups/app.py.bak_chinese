# ============================================================================
# OpenCV 摄像头（项目1）
# ============================================================================
_cameras = {}            # camera_id -> cv2.VideoCapture
_cameras_lock = threading.Lock()

try:
    import cv2
    _cv2_available = True
except ImportError:
    cv2 = None
    _cv2_available = False
    print("警告: opencv-python 未安装，服务端摄像头不可用")

def get_camera(camera_id=0):
    """按索引获取摄像头，支持多个摄像头并存（如内置+USB外接）"""
    if not _cv2_available:
        return None
    with _cameras_lock:
        if camera_id not in _cameras or _cameras[camera_id] is None:
            try:
                cap = cv2.VideoCapture(camera_id)
                cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
                cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
                cap.set(cv2.CAP_PROP_FPS, 30)
                if not cap.isOpened():
                    cap.release()
                    return None
                _cameras[camera_id] = cap
            except Exception:
                return None
    return _cameras.get(camera_id)

def release_camera(camera_id=0):
    """释放指定摄像头，不传 id 则释放全部"""
    global _cameras
    with _cameras_lock:
        if camera_id is None:
            for cap in _cameras.values():
                if cap is not None:
                    cap.release()
            _cameras = {}
        elif camera_id in _cameras and _cameras[camera_id] is not None:
            _cameras[camera_id].release()
            _cameras[camera_id] = None

def generate_frames(camera_id=0):
    camera = get_camera(camera_id)
    if camera is None:
        return
    try:
        while True:
            with _cameras_lock:
                cap = _cameras.get(camera_id)
                if cap is None:
                    break
                success, frame = cap.read()
            if not success:
                time.sleep(0.05)
                continue
            ret, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 80])
            if not ret:
                continue
            yield (b'--frame\r\nContent-Type: image/jpeg\r\n\r\n' + buffer.tobytes() + b'\r\n')
    except GeneratorExit:
        pass
    finally:
        release_camera(camera_id)

# ============================================================================
# 预警系统（项目2）
# ============================================================================
alerts_lock = threading.Lock()
alerts_queue = queue.Queue()
try:
    if os.path.isfile(ALERTS_FILE):
        with open(ALERTS_FILE, 'r', encoding='utf-8') as f:
            alerts_store = json.load(f)
    else:
        alerts_store = []
except Exception:
    alerts_store = []

def save_alerts():
    try:
        with alerts_lock:
            with open(ALERTS_FILE, 'w', encoding='utf-8') as f:
                json.dump(alerts_store, f, ensure_ascii=False, indent=2)
    except Exception:
        pass

def push_alert(alert):
    with alerts_lock:
        alerts_store.insert(0, alert)
        del alerts_store[200:]
        save_alerts()
    try:
        alerts_queue.put(alert, block=False)
    except Exception:
        pass

