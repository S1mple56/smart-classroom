            photos.setFont(QFont('Noto Sans CJK SC', 11))
            photos.setStyleSheet(f'color: {COLORS["text_dim"]};')

            card_layout.addWidget(name)
            card_layout.addWidget(sid)
            card_layout.addStretch()
            card_layout.addWidget(photos)

            self.list_layout.addWidget(card)

        self.list_layout.addStretch()


# ============================================================================
# 页面 5：数据总览
# ============================================================================
class DashboardPage(QWidget):
    def __init__(self):
        super().__init__()
        layout = QVBoxLayout(self)
        layout.setContentsMargins(12, 12, 12, 12)

        title = QLabel('📊 数据总览')
        title.setFont(QFont('Noto Sans CJK SC', 18, QFont.Bold))
        title.setStyleSheet(f'color: {COLORS["text"]};')
        layout.addWidget(title)

        btn_refresh = QPushButton('🔄 刷新')
        btn_refresh.setFont(QFont('Noto Sans CJK SC', 12))
        btn_refresh.setFixedHeight(44)
        btn_refresh.setStyleSheet(f'''
            QPushButton {{
                background: {COLORS['primary']};
                color: white;
                border-radius: 8px;
                padding: 0 16px;
            }}
            QPushButton:pressed {{ background: {COLORS['accent']}; }}
        ''')
        btn_refresh.clicked.connect(self.load_data)
        layout.addWidget(btn_refresh)

        # 统计卡片
        cards_layout = QGridLayout()
        cards_layout.setSpacing(12)

        self.card_students = StatCard('学生人数', COLORS['primary'])
        self.card_attendance = StatCard('考勤记录', COLORS['success'])
        self.card_yolo = StatCard('检测次数', COLORS['warning'])

        cards_layout.addWidget(self.card_students, 0, 0)
        cards_layout.addWidget(self.card_attendance, 0, 1)
        cards_layout.addWidget(self.card_yolo, 0, 2)

        layout.addLayout(cards_layout)

        # 详细信息
        self.detail_label = QLabel('加载中...')
        self.detail_label.setFont(QFont('Noto Sans CJK SC', 13))
        self.detail_label.setStyleSheet(f'color: {COLORS["text_dim"]};')
        self.detail_label.setWordWrap(True)
        self.detail_label.setAlignment(Qt.AlignTop)
        layout.addWidget(self.detail_label, 1)

        self.load_data()

    def load_data(self):
        threading.Thread(target=self._do_load, daemon=True).start()

    def _do_load(self):
        # 并发请求
        import urllib.request, json

        def fetch(url):
            try:
                req = urllib.request.Request(BACKEND_URL + url)
                with urllib.request.urlopen(req, timeout=5) as resp:
                    return json.loads(resp.read().decode('utf-8'))
            except:
                return None

        students = fetch('/api/students')
        records = fetch('/api/face/records')
        yolo = fetch('/api/yolo/stats')

        s_count = len(students.get('students', [])) if students else 0
        r_count = len(records.get('records', [])) if records else 0
        y_count = yolo.get('total', 0) if yolo else 0

        detail = f'学生总数: {s_count}\n'
        detail += f'考勤记录: {r_count} 条\n'
        detail += f'行为检测: {y_count} 次\n'

        if students and students.get('students'):
            names = [s.get('name', '') for s in students['students'][:10]]
            detail += f'\n学生列表: {", ".join(names)}'
            if s_count > 10:
                detail += f' 等{s_count}人'

        QTimer.singleShot(0, lambda: self.card_students.set_value(s_count))
        QTimer.singleShot(0, lambda: self.card_attendance.set_value(r_count))
        QTimer.singleShot(0, lambda: self.card_yolo.set_value(y_count))
        QTimer.singleShot(0, lambda: self.detail_label.setText(detail))


# ============================================================================
# 页面 6：AI 助手
# ============================================================================
class ChatPage(QWidget):
    def __init__(self):
        super().__init__()
        layout = QVBoxLayout(self)
        layout.setContentsMargins(12, 12, 12, 12)

        # 标题
        title = QLabel('🤖 AI 助手')
        title.setFont(QFont('Noto Sans CJK SC', 18, QFont.Bold))
        title.setStyleSheet(f'color: {COLORS["text"]};')
        layout.addWidget(title)

        # 聊天区域
        self.chat_area = QTextEdit()
        self.chat_area.setReadOnly(True)
        self.chat_area.setFont(QFont('Noto Sans CJK SC', 13))
        self.chat_area.setStyleSheet(f'''
            QTextEdit {{
                background: {COLORS['bg']};
                color: {COLORS['text']};
                border: 1px solid {COLORS['accent']};
                border-radius: 12px;
                padding: 12px;
            }}
        ''')
        layout.addWidget(self.chat_area, 1)

        # 输入框 + 发送按钮
        input_layout = QHBoxLayout()

        self.input_field = QLineEdit()
        self.input_field.setPlaceholderText('输入问题...')
        self.input_field.setFont(QFont('Noto Sans CJK SC', 13))
        self.input_field.setFixedHeight(48)
        self.input_field.setStyleSheet(f'''
            QLineEdit {{
                background: {COLORS['card']};
                color: {COLORS['text']};
                border: 1px solid {COLORS['accent']};
                border-radius: 8px;
                padding: 0 12px;
            }}
        ''')
        self.input_field.returnPressed.connect(self.send_message)

        btn_send = QPushButton('发送')
        btn_send.setFont(QFont('Noto Sans CJK SC', 13, QFont.Bold))
        btn_send.setFixedSize(80, 48)
        btn_send.setStyleSheet(f'''
            QPushButton {{
                background: {COLORS['primary']};
                color: white;
                border-radius: 8px;
            }}
            QPushButton:pressed {{ background: {COLORS['accent']}; }}
        ''')
        btn_send.clicked.connect(self.send_message)

        input_layout.addWidget(self.input_field, 1)
        input_layout.addWidget(btn_send, 0)

        layout.addLayout(input_layout)

        # 欢迎消息
        self.add_message('AI', '你好！我是课堂智能监测系统的AI助手，有什么可以帮你的吗？')

    def add_message(self, role, text):
        if role == 'AI':
            self.chat_area.append(f'<p style="color: {COLORS["primary"]};"><b>🤖 AI：</b>{text}</p>')
        else:
            self.chat_area.append(f'<p style="color: {COLORS["success"]};"><b>👤 我：</b>{text}</p>')

    def send_message(self):
        text = self.input_field.text().strip()
        if not text:
            return

        self.add_message('user', text)
        self.input_field.clear()

        # 后台请求
        threading.Thread(target=self._do_chat, args=(text,), daemon=True).start()

    def _do_chat(self, text):
        result = api_post('/api/chat', {'messages': [{'role': 'user', 'content': text}]})
        if result and result.get('ok'):
            reply = result.get('reply', '抱歉，无法回答。')
        else:
            reply = 'AI 服务暂时不可用，请稍后再试。'
        # 用信号回到主线程更新 UI
        QTimer.singleShot(0, lambda: self.add_message('AI', reply))


# ============================================================================
# 主窗口
# ============================================================================
class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle(f'智瞳课堂 - {LOCAL_IP}:5000')
        self.setMinimumSize(1024, 600)

        # 全屏（触摸屏）
        self.showFullScreen()

        # 中央窗口
        central = QWidget()
        self.setCentralWidget(central)
        main_layout = QVBoxLayout(central)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)

        # 页面堆栈
        self.pages = QStackedWidget()
        self.monitor_page = MonitorPage()
        self.face_page = FaceAttendancePage()
        self.students_page = StudentsPage()
        self.attendance_page = AttendancePage()
        self.dashboard_page = DashboardPage()
        self.chat_page = ChatPage()

        self.pages.addWidget(self.monitor_page)
        self.pages.addWidget(self.face_page)
        self.pages.addWidget(self.students_page)
        self.pages.addWidget(self.attendance_page)
        self.pages.addWidget(self.dashboard_page)
        self.pages.addWidget(self.chat_page)

        # 底部导航栏
        nav = QWidget()
        nav.setFixedHeight(64)
        nav.setStyleSheet(f'background: {COLORS["card"]};')
        nav_layout = QHBoxLayout(nav)
        nav_layout.setContentsMargins(0, 0, 0, 0)
        nav_layout.setSpacing(0)

        self.nav_buttons = []
        nav_items = [
            ('📹 实时监测', 0),
            ('👤 人脸考勤', 1),
            ('📚 学生档案', 2),
            ('📋 考勤记录', 3),
            ('📊 数据总览', 4),
            ('🤖 AI 助手', 5),
        ]

        for text, index in nav_items:
            btn = QPushButton(text)
            btn.setFont(QFont('Noto Sans CJK SC', 14, QFont.Bold))
            btn.setFixedHeight(64)
            btn.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Fixed)
            btn.setStyleSheet(f'''
                QPushButton {{
                    background: transparent;
                    color: {COLORS["text_dim"]};
                    border: none;
                    border-bottom: 3px solid transparent;
                }}
                QPushButton:checked {{
                    color: {COLORS["primary"]};
                    border-bottom: 3px solid {COLORS["primary"]};
                }}
            ''')
            btn.setCheckable(True)
            btn.clicked.connect(lambda checked, i=index: self.switch_page(i))
            nav_layout.addWidget(btn)
            self.nav_buttons.append(btn)

        # IP 地址显示
        ip_bar = QWidget()
        ip_bar.setFixedHeight(28)
        ip_bar.setStyleSheet(f'background: {COLORS["accent"]};')
        ip_layout = QHBoxLayout(ip_bar)
        ip_layout.setContentsMargins(12, 0, 12, 0)

        ip_label = QLabel(f'🌐 访问地址: http://{LOCAL_IP}:5000')
        ip_label.setFont(QFont('Noto Sans CJK SC', 11))
        ip_label.setStyleSheet(f'color: {COLORS["text_dim"]};')
        ip_layout.addWidget(ip_label)
        ip_layout.addStretch()

        main_layout.addWidget(self.pages, 1)
        main_layout.addWidget(ip_bar, 0)
        main_layout.addWidget(nav, 0)

        # 默认选中第一个
        self.nav_buttons[0].setChecked(True)

        # 样式
        self.setStyleSheet(f'''
            QMainWindow {{ background: {COLORS['bg']}; }}
            QScrollBar:vertical {{
                background: {COLORS['bg']};
                width: 8px;
                border-radius: 4px;
            }}
            QScrollBar::handle:vertical {{
                background: {COLORS['accent']};
                border-radius: 4px;
            }}
        ''')

    def switch_page(self, index):
        self.pages.setCurrentIndex(index)
        for i, btn in enumerate(self.nav_buttons):
            btn.setChecked(i == index)

    def closeEvent(self, event):
        self.monitor_page.stop_camera()
        self.face_page.stop_camera()
        event.accept()


# ============================================================================
# 启动
# ============================================================================
if __name__ == '__main__':
    app = QApplication(sys.argv)
    app.setFont(QFont('Noto Sans CJK SC', 12))

    window = MainWindow()
    window.show()

    sys.exit(app.exec_())
