#!/usr/bin/env python3
"""
智瞳课堂 - Qt 触摸屏界面
适用于 7寸 1024x600 触摸屏（RK3588）
依赖：pip install PyQt5 opencv-python requests
"""
import sys, os, json, time, threading

# 解决 OpenCV 和 PyQt5 的 Qt 插件冲突
# 必须在 import cv2 或 PyQt5 之前设置
os.environ.pop('QT_QPA_PLATFORM_PLUGIN_PATH', None)
os.environ.pop('OPENCV_IO_PLUGIN_PATH', None)
os.environ['QT_QPA_PLATFORM_PLUGIN_PATH'] = '/usr/lib/aarch64-linux-gnu/qt5/plugins/platforms'
from datetime import datetime

from PyQt5.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
    QLabel, QPushButton, QStackedWidget, QTextEdit, QLineEdit,
    QScrollArea, QFrame, QGridLayout, QSizePolicy
)
from PyQt5.QtCore import Qt, QTimer, pyqtSignal, QThread, QSize
from PyQt5.QtGui import QImage, QPixmap, QFont, QColor, QPainter, QPen

import cv2
import numpy as np
from PIL import Image, ImageDraw, ImageFont

# ============================================================================
# 配置
# ============================================================================
BACKEND_URL = 'http://127.0.0.1:5000'
CAMERA_INDEX = 21  # 摄像头索引（USB 摄像头在 21）
IMG_SIZE = 640    # 推理尺寸

def get_local_ip():
    """获取本机局域网 IP"""
    import socket
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(('8.8.8.8', 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except:
        return '未知'

LOCAL_IP = get_local_ip()

# 颜色主题
COLORS = {
    'bg': '#1a1a2e',
    'card': '#16213e',
    'primary': '#4A90D9',
    'success': '#27ae60',
    'warning': '#f39c12',
    'danger': '#e74c3c',
    'text': '#ffffff',
    'text_dim': '#8899aa',
    'accent': '#0f3460',
}

CLASS_COLORS = {
    'hand-raising': '#1abc9c',
    'reading': '#3498db',
    'writing': '#27ae60',
    'using phone': '#f39c12',
    'bowing the head': '#9b59b6',
    'leaning over the table': '#e74c3c',
}


def draw_chinese_text(img, text, position, font_path='/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc', font_size=24, color=(255, 255, 255)):
    """在图片上绘制中文文本"""
    pil_img = Image.fromarray(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))
    draw = ImageDraw.Draw(pil_img)
    try:
        font = ImageFont.truetype(font_path, font_size)
    except:
        font = ImageFont.load_default()
    draw.text(position, text, font=font, fill=color)
    return cv2.cvtColor(np.array(pil_img), cv2.COLOR_RGB2BGR)

CLASS_CN = {
    'hand-raising': '举手',
    'reading': '阅读',
    'writing': '写字',
    'using phone': '用手机',
    'bowing the head': '低头',
    'leaning over the table': '趴桌子',
}


# ============================================================================
# 后端 API 通信
# ============================================================================
import urllib.request

def api_get(path):
    try:
        req = urllib.request.Request(f'{BACKEND_URL}{path}')
        with urllib.request.urlopen(req, timeout=5) as resp:
            return json.loads(resp.read().decode('utf-8'))
    except:
        return None

def api_post(path, data, is_json=True):
    try:
        if is_json:
            body = json.dumps(data).encode('utf-8')
            headers = {'Content-Type': 'application/json'}
        else:
            # 发送表单数据
            body = urllib.parse.urlencode(data).encode('utf-8')
            headers = {'Content-Type': 'application/x-www-form-urlencoded'}
        req = urllib.request.Request(
            f'{BACKEND_URL}{path}',
            data=body,
            headers=headers
        )
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode('utf-8'))
    except:
        return None


# ============================================================================
# 摄像头线程（从 Flask 后端获取视频流）
# ============================================================================
class CameraThread(QThread):
    frame_ready = pyqtSignal(np.ndarray)
    error = pyqtSignal(str)

    def __init__(self, camera_index=0):
        super().__init__()
        self.camera_index = camera_index
        self.running = False

    def run(self):
        self.running = True
        url = f'{BACKEND_URL}/video_feed?camera={self.camera_index}'

        try:
            req = urllib.request.Request(url)
            resp = urllib.request.urlopen(req, timeout=10)
            buffer = b''

            while self.running:
                chunk = resp.read(4096)
                if not chunk:
                    break
                buffer += chunk

                # 查找 JPEG 边界
                start = buffer.find(b'\xff\xd8')
                end = buffer.find(b'\xff\xd9')
                if start != -1 and end != -1 and end > start:
                    jpg_data = buffer[start:end+2]
                    buffer = buffer[end+2:]

                    # 解码 JPEG
                    nparr = np.frombuffer(jpg_data, np.uint8)
                    frame = cv2.imdecode(nparr, cv2.IMREAD_COLOR)
                    if frame is not None:
                        self.frame_ready.emit(frame)
        except Exception as e:
            self.error.emit(f'视频流连接失败: {str(e)}')

    def stop(self):
        self.running = False
        self.wait(3000)


# ============================================================================
# 推理线程
# ============================================================================
class InferThread(QThread):
    result_ready = pyqtSignal(dict)
    error = pyqtSignal(str)

    def __init__(self):
        super().__init__()
        self.frame = None
        self.running = False

    def set_frame(self, frame):
        self.frame = frame

    def run(self):
        self.running = True
        while self.running:
            if self.frame is not None:
                frame = self.frame
                self.frame = None
                try:
                    # 编码为 base64
                    _, buf = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 80])
                    import base64
                    img_b64 = 'data:image/jpeg;base64,' + base64.b64encode(buf).decode('utf-8')

                    result = api_post('/api/yolo/predict-frame', {'image': img_b64})
                    if result:
                        self.result_ready.emit(result)
                except Exception as e:
                    self.error.emit(str(e))
            else:
                time.sleep(0.1)

    def stop(self):
        self.running = False
        self.wait(3000)


# ============================================================================
# 统计卡片
# ============================================================================
class StatCard(QFrame):
    def __init__(self, label, color=COLORS['primary']):
        super().__init__()
        self.setStyleSheet(f'''
            QFrame {{
                background: {COLORS['card']};
                border-radius: 12px;
                border-left: 4px solid {color};
                padding: 8px;
            }}
        ''')
        layout = QVBoxLayout(self)
        layout.setContentsMargins(12, 8, 12, 8)

        self.value_label = QLabel('0')
        self.value_label.setFont(QFont('Noto Sans CJK SC', 24, QFont.Bold))
        self.value_label.setStyleSheet(f'color: {color};')
        self.value_label.setAlignment(Qt.AlignCenter)

        self.name_label = QLabel(label)
        self.name_label.setFont(QFont('Noto Sans CJK SC', 11))
        self.name_label.setStyleSheet(f'color: {COLORS["text_dim"]};')
        self.name_label.setAlignment(Qt.AlignCenter)

        layout.addWidget(self.value_label)
        layout.addWidget(self.name_label)

    def set_value(self, val):
        self.value_label.setText(str(val))


# ============================================================================
# 页面 1：实时监测
# ============================================================================
class MonitorPage(QWidget):
    def __init__(self):
        super().__init__()
        self.camera_thread = None
        self.infer_thread = None
        self.current_frame = None
        self.detections = []

        layout = QHBoxLayout(self)
        layout.setContentsMargins(8, 8, 8, 8)
        layout.setSpacing(8)

        # 左侧：摄像头画面
        left = QWidget()
        left_layout = QVBoxLayout(left)
        left_layout.setContentsMargins(0, 0, 0, 0)

        self.video_label = QLabel()
        self.video_label.setAlignment(Qt.AlignCenter)
        self.video_label.setMinimumSize(640, 400)
        self.video_label.setStyleSheet(f'''
            background: {COLORS['bg']};
            border-radius: 12px;
            border: 2px solid {COLORS['accent']};
        ''')
        self.video_label.setText('📷 点击开启摄像头')
        self.video_label.setFont(QFont('Noto Sans CJK SC', 16))

        # 控制按钮
        btn_layout = QHBoxLayout()
        self.btn_camera = QPushButton('📷 开启摄像头')
        self.btn_camera.setFont(QFont('Noto Sans CJK SC', 13))
        self.btn_camera.setFixedHeight(48)
        self.btn_camera.setStyleSheet(f'''
            QPushButton {{
                background: {COLORS['primary']};
                color: white;
                border-radius: 8px;
                padding: 0 20px;
            }}
            QPushButton:pressed {{ background: {COLORS['accent']}; }}
        ''')
        self.btn_camera.clicked.connect(self.toggle_camera)

        self.btn_infer = QPushButton('🔍 开始检测')
        self.btn_infer.setFont(QFont('Noto Sans CJK SC', 13))
        self.btn_infer.setFixedHeight(48)
        self.btn_infer.setEnabled(False)
        self.btn_infer.setStyleSheet(f'''
            QPushButton {{
                background: {COLORS['success']};
                color: white;
                border-radius: 8px;
                padding: 0 20px;
            }}
            QPushButton:disabled {{ background: #555; }}
            QPushButton:pressed {{ background: #1e8449; }}
        ''')
        self.btn_infer.clicked.connect(self.toggle_infer)

        btn_layout.addWidget(self.btn_camera)
        btn_layout.addWidget(self.btn_infer)

        left_layout.addWidget(self.video_label, 1)
        left_layout.addLayout(btn_layout)

        # 右侧：统计面板
        right = QWidget()
        right.setFixedWidth(320)
        right_layout = QVBoxLayout(right)
        right_layout.setContentsMargins(0, 0, 0, 0)
        right_layout.setSpacing(6)

        # 统计卡片
        self.stat_cards = {}
        stats = [
            ('举手', 'hand-raising'),
            ('阅读', 'reading'),
            ('写作', 'writing'),
            ('玩手机', 'using phone'),
            ('低头', 'bowing the head'),
            ('靠桌子', 'leaning over the table'),
        ]
        for cn_name, en_name in stats:
            color = CLASS_COLORS.get(en_name, COLORS['primary'])
            card = StatCard(cn_name, color)
            self.stat_cards[en_name] = card
            right_layout.addWidget(card)

        right_layout.addStretch()

        # 状态栏
        self.status_label = QLabel('未连接')
        self.status_label.setFont(QFont('Noto Sans CJK SC', 11))
        self.status_label.setStyleSheet(f'color: {COLORS["text_dim"]};')
        self.status_label.setAlignment(Qt.AlignCenter)
        right_layout.addWidget(self.status_label)

        layout.addWidget(left, 1)
        layout.addWidget(right, 0)

        # 推理定时器
        self.infer_timer = QTimer()
        self.infer_timer.timeout.connect(self.do_infer)

    def toggle_camera(self):
        if self.camera_thread and self.camera_thread.running:
            self.stop_camera()
        else:
            self.start_camera()

    def start_camera(self):
        self.camera_thread = CameraThread(CAMERA_INDEX)
        self.camera_thread.frame_ready.connect(self.on_frame)
        self.camera_thread.error.connect(self.on_camera_error)
        self.camera_thread.start()
        self.btn_camera.setText('⏹ 关闭摄像头')
        self.btn_infer.setEnabled(True)
        self.status_label.setText('摄像头已开启')

    def stop_camera(self):
        if self.infer_timer.isActive():
            self.infer_timer.stop()
        if self.camera_thread:
            self.camera_thread.stop()
        if self.infer_thread:
            self.infer_thread.stop()
        self.btn_camera.setText('📷 开启摄像头')
        self.btn_infer.setEnabled(False)
        self.btn_infer.setText('🔍 开始检测')
        self.status_label.setText('未连接')
        self.video_label.setText('📷 点击开启摄像头')

    def on_frame(self, frame):
        self.current_frame = frame
        # 显示帧（带检测框）
        display = frame.copy()
        for det in self.detections:
            cls = det.get('class_name', '')
            conf = det.get('conf', 0)
            xyxy = det.get('xyxy', [0, 0, 0, 0])
            h, w = display.shape[:2]
            x1 = int(xyxy[0] * w)
            y1 = int(xyxy[1] * h)
            x2 = int(xyxy[2] * w)
            y2 = int(xyxy[3] * h)

            color_hex = CLASS_COLORS.get(cls, '#4A90D9')
            r, g, b = int(color_hex[1:3], 16), int(color_hex[3:5], 16), int(color_hex[5:7], 16)

            cv2.rectangle(display, (x1, y1), (x2, y2), (b, g, r), 2)
            label = f'{CLASS_CN.get(cls, cls)} {conf*100:.0f}%'
            display = draw_chinese_text(display, label, (x1, y1 - 28), font_size=20, color=(b, g, r))

        # 转换为 QPixmap
        rgb = cv2.cvtColor(display, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        qimg = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
        pixmap = QPixmap.fromImage(qimg)

        # 缩放适应标签
        scaled = pixmap.scaled(self.video_label.size(), Qt.KeepAspectRatio, Qt.SmoothTransformation)
        self.video_label.setPixmap(scaled)

    def on_camera_error(self, msg):
        self.status_label.setText(f'错误: {msg}')

    def toggle_infer(self):
        if self.infer_timer.isActive():
            self.infer_timer.stop()
            self.btn_infer.setText('🔍 开始检测')
            self.status_label.setText('检测已停止')
        else:
            self.infer_timer.start(2000)  # 每2秒推理一次
            self.btn_infer.setText('⏹ 停止检测')
            self.status_label.setText('检测中...')

    def do_infer(self):
        if self.current_frame is None:
            return
        # 在后台线程推理
        frame = self.current_frame.copy()
        threading.Thread(target=self._infer_worker, args=(frame,), daemon=True).start()

    def _infer_worker(self, frame):
        try:
            _, buf = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 80])
            import base64
            img_b64 = 'data:image/jpeg;base64,' + base64.b64encode(buf).decode('utf-8')
            result = api_post('/api/yolo/predict-frame', {'image': img_b64})
            if result and 'stats' in result:
                self.on_infer_result(result)
        except:
            pass

    def on_infer_result(self, result):
        stats = result.get('stats', {})
        counts = stats.get('display_counts', {})
        self.detections = result.get('boxes', [])

        for en_name, card in self.stat_cards.items():
            card.set_value(counts.get(en_name, 0))


