        self.status_label.setAlignment(Qt.AlignCenter)
        right_layout.addWidget(self.status_label)

        layout.addWidget(left, 1)
        layout.addWidget(right, 0)

        self.load_summary()

    def toggle_camera(self):
        if self.camera_thread and self.camera_thread.running:
            self.stop_camera()
        else:
            self.start_camera()

    def start_camera(self):
        self.camera_thread = CameraThread(CAMERA_INDEX)
        self.camera_thread.frame_ready.connect(self.on_frame)
        self.camera_thread.error.connect(lambda msg: self.status_label.setText(f'错误: {msg}'))
        self.camera_thread.start()
        self.btn_camera.setText('⏹ 关闭摄像头')
        self.btn_freeze.setEnabled(True)
        self.btn_snap.setEnabled(True)
        self.status_label.setText('摄像头已开启')
        self.frozen = False

    def stop_camera(self):
        if self.camera_thread:
            self.camera_thread.stop()
        self.btn_camera.setText('📷 开启摄像头')
        self.btn_freeze.setEnabled(False)
        self.btn_snap.setEnabled(False)
        self.status_label.setText('未连接')
        self.video_label.setText('📷 点击开启摄像头')
        self.frozen = False

    def toggle_freeze(self):
        self.frozen = not self.frozen
        self.btn_freeze.setText('▶ 继续' if self.frozen else '⏸ 冻结')

    def on_frame(self, frame):
        if self.frozen:
            return
        self.current_frame = frame
        rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = rgb.shape
        qimg = QImage(rgb.data, w, h, ch * w, QImage.Format_RGB888)
        pixmap = QPixmap.fromImage(qimg)
        scaled = pixmap.scaled(self.video_label.size(), Qt.KeepAspectRatio, Qt.SmoothTransformation)
        self.video_label.setPixmap(scaled)

    def snap_and_submit(self):
        if self.current_frame is None:
            return
        self.frozen = True
        self.btn_freeze.setText('▶ 继续')
        self.status_label.setText('识别中...')

        frame = self.current_frame.copy()
        threading.Thread(target=self._do_attendance, args=(frame,), daemon=True).start()

    def _do_attendance(self, frame):
        try:
            _, buf = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 90])
            import base64
            img_b64 = 'data:image/jpeg;base64,' + base64.b64encode(buf).decode('utf-8')
            result = api_post('/api/face/attendance', {'captured_image': img_b64}, is_json=False)
            if result and result.get('ok'):
                student = result.get('student', {})
                name = student.get('name', '未知')
                sid = student.get('student_id', '')
                msg = f'{name} 已考勤成功'
                sid = result.get('student_id', '')
                msg = f'考勤成功: {name} ({sid})'
            else:
                msg = result.get('message', '考勤失败') if result else '考勤失败'
            QTimer.singleShot(0, lambda: self.status_label.setText(msg))
            QTimer.singleShot(0, self.load_summary)
        except Exception as e:
            QTimer.singleShot(0, lambda: self.status_label.setText(f'错误: {str(e)}'))

    def manual_submit(self):
        sid = self.sid_input.text().strip()
        if not sid:
            self.status_label.setText('请输入学号')
            return
        self.status_label.setText('提交中...')
        threading.Thread(target=self._do_manual, args=(sid,), daemon=True).start()

    def _do_manual(self, sid):
        result = api_post('/api/face/attendance', {'student_id': sid}, is_json=False)
        if result and result.get('ok'):
            msg = result.get('message', '考勤成功')
            msg = f'考勤成功: {name} ({sid})'
        else:
            msg = result.get('message', '考勤失败') if result else '考勤失败'
        QTimer.singleShot(0, lambda: self.status_label.setText(msg))
        QTimer.singleShot(0, self.load_summary)

    def load_summary(self):
        threading.Thread(target=self._do_load_summary, daemon=True).start()

    def _do_load_summary(self):
        data = api_get('/api/face/attendance/summary')
        if data and data.get('ok'):
            today = data.get('today', {})
            total = today.get('total', 0)
            students = today.get('students', [])
            text = f'今日考勤: {total} 人\n'
            if students:
                names = [s.get('name', '') for s in students[:10]]
                text += '、'.join(names)
                if total > 10:
                    text += f' 等{total}人'
        else:
            text = '暂无考勤数据'
        QTimer.singleShot(0, lambda: self.summary_label.setText(text))


# ============================================================================
# 页面 3：考勤记录
# ============================================================================
class AttendancePage(QWidget):
    def __init__(self):
        super().__init__()
        layout = QVBoxLayout(self)
        layout.setContentsMargins(12, 12, 12, 12)

        # 标题
        title = QLabel('📋 考勤记录')
        title.setFont(QFont('Noto Sans CJK SC', 18, QFont.Bold))
        title.setStyleSheet(f'color: {COLORS["text"]};')
        layout.addWidget(title)

        # 刷新按钮
        btn_refresh = QPushButton('🔄 刷新')
        btn_refresh.setFont(QFont('Noto Sans CJK SC', 12))
        btn_refresh.setFixedHeight(44)
        btn_refresh.setStyleSheet(f'''
            QPushButton {{
                background: {COLORS['primary']};
                color: white;
                border-radius: 8px;
                padding: 0 16px;
            }}
            QPushButton:pressed {{ background: {COLORS['accent']}; }}
        ''')
        btn_refresh.clicked.connect(self.load_data)
        layout.addWidget(btn_refresh)

        # 滚动区域
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setStyleSheet(f'QScrollArea {{ border: none; background: {COLORS["bg"]}; }}')

        self.list_widget = QWidget()
        self.list_layout = QVBoxLayout(self.list_widget)
        self.list_layout.setSpacing(6)
        scroll.setWidget(self.list_widget)

        layout.addWidget(scroll, 1)

        self.load_data()

    def load_data(self):
        # 清空
        while self.list_layout.count():
            child = self.list_layout.takeAt(0)
            if child.widget():
                child.widget().deleteLater()

        data = api_get('/api/face/records')
        records = data.get('records', []) if data else []

        if not records:
            empty = QLabel('暂无考勤记录')
            empty.setFont(QFont('Noto Sans CJK SC', 14))
            empty.setStyleSheet(f'color: {COLORS["text_dim"]};')
            empty.setAlignment(Qt.AlignCenter)
            self.list_layout.addWidget(empty)
            return

        for rec in records[-50:]:  # 最近50条
            card = QFrame()
            card.setStyleSheet(f'''
                QFrame {{
                    background: {COLORS['card']};
                    border-radius: 8px;
                    padding: 8px;
                }}
            ''')
            card_layout = QHBoxLayout(card)

            name = QLabel(rec.get('name', '未知'))
            name.setFont(QFont('Noto Sans CJK SC', 13, QFont.Bold))
            name.setStyleSheet(f'color: {COLORS["text"]};')

            sid = QLabel(rec.get('student_id', ''))
            sid.setFont(QFont('Noto Sans CJK SC', 11))
            sid.setStyleSheet(f'color: {COLORS["text_dim"]};')

            time_str = QLabel(rec.get('time', ''))
            time_str.setFont(QFont('Noto Sans CJK SC', 11))
            time_str.setStyleSheet(f'color: {COLORS["text_dim"]};')

            card_layout.addWidget(name)
            card_layout.addWidget(sid)
            card_layout.addStretch()
            card_layout.addWidget(time_str)

            self.list_layout.addWidget(card)

        self.list_layout.addStretch()


